# Required environment variables. Copy to .env.local for local dev,
# and set these in Vercel → Project → Settings → Environment Variables.

# Supabase project URL (Project Settings → API → Project URL)
SUPABASE_URL=https://tzbshbwjhvmezxexapfp.supabase.co

# Supabase service role key (Project Settings → API → service_role key)
# WARNING: Bypasses Row Level Security. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Salt used to hash respondent IPs before storing them.
# Generate once with: openssl rand -hex 32
IP_HASH_SALT=
